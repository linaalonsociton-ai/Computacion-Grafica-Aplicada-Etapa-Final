function togglePanelCalibrador() {
  panelAbierto = !panelAbierto;
  panelEl.style.width = panelAbierto ? '270px' : '0px';
}

// Llamada desde procesarAudio() para actualizar los medidores
function actualizarMedidoresPanel(rms, noise, ratio, pitchCount) {
  if (!elVolBar || !panelAbierto) return;
  const pct = Math.min(100, rms * 800);
  elVolBar.style.width   = pct.toFixed(1) + '%';
  elVolNum.textContent   = rms.toFixed(4);
  elNoiseNum.textContent = noise.toFixed(4);

  const rpct = Math.min(100, ratio * 100);
  elRatioBar.style.width  = rpct.toFixed(1) + '%';
  elRatioNum.textContent  = Math.round(rpct) + '%';
  elPitchDots.textContent = pitchCount;
}

// Llamada desde iniciarMicrofono() cuando el mic se activa
function actualizarEstadoMicPanel(activo) {
  if (!elMicStatus) return;
  elMicStatus.textContent  = activo ? 'MIC ACTIVO' : 'MIC INACTIVO';
  elMicStatus.style.color  = activo ? '#88B914' : '#666';
  elMicStatus.style.background = activo ? '#0C3018' : '#1E2D1F';
}
